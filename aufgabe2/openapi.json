{
  "openapi": "3.0.3",
  "info": {
    "title": "Math Factory REST API",
    "version": "1.0.0",
    "description": "REST interface for managing the operations of the Math Factory server."
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service is reachable."
          }
        }
      }
    },
    "/operations": {
      "get": {
        "summary": "List all managed operations",
        "responses": {
          "200": {
            "description": "All configured operations",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "operations": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Operation"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/operations/{name}": {
      "parameters": [
        {
          "name": "name",
          "in": "path",
          "required": true,
          "schema": {
            "type": "string",
            "enum": [
              "addition",
              "subtraction",
              "multiplication",
              "division",
              "factorial",
              "power"
            ]
          }
        }
      ],
      "get": {
        "summary": "Get a single operation",
        "responses": {
          "200": {
            "description": "Operation configuration",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Operation"
                }
              }
            }
          },
          "404": {
            "description": "Operation not found"
          }
        }
      },
      "patch": {
        "summary": "Update cost and/or enabled state",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OperationUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Operation"
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          },
          "404": {
            "description": "Operation not found"
          }
        }
      },
      "put": {
        "summary": "Replace configurable fields of an operation",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OperationUpdate"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Operation"
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          },
          "404": {
            "description": "Operation not found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Operation": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "expression": {
            "type": "string"
          },
          "cost": {
            "type": "integer",
            "minimum": 0
          },
          "enabled": {
            "type": "boolean"
          }
        },
        "required": [
          "name",
          "description",
          "expression",
          "cost",
          "enabled"
        ]
      },
      "OperationUpdate": {
        "type": "object",
        "properties": {
          "cost": {
            "type": "integer",
            "minimum": 0
          },
          "enabled": {
            "type": "boolean"
          }
        }
      }
    }
  }
}

